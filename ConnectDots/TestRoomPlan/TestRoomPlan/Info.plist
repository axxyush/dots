<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>Default Configuration</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Dots needs camera access to scan rooms using LiDAR and to capture room photos for AI object identification.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Dots needs microphone access for voice conversation with scanned rooms.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Dots uses speech recognition to let you ask questions about scanned rooms.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Allow HTTP during development (ngrok and Vultr use HTTPS — remove before App Store submission) -->
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
</dict>
</plist>
